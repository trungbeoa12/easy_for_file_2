# Backend environment variables for local/Railway deploy (never commit real secrets).
MONGODB_URI=<PASTE_YOUR_MONGODB_ATLAS_URI_HERE>
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,https://your-frontend.vercel.app
PORT=3000

# Auth (Phase 4) — random string ≥ 16 chars, e.g. openssl rand -hex 32
JWT_SECRET=<GENERATE_A_STRONG_SECRET_MIN_16_CHARS>
# Optional: JWT_EXPIRES_IN=7d
